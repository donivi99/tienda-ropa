{
  "name": "tienda-ropa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "start": "cross-env NODE_ENV=production npm run start --workspace=backend",
    "lint": "npm run lint --workspace=frontend",
    "test": "npm run test --workspace=frontend && npm run test --workspace=backend",
    "preview": "npm run preview --workspace=frontend",
    "seed:admin": "npm run seed:admin --workspace=backend",
    "seed:products": "npm run seed:products --workspace=backend",
    "migrate:categories": "npm run migrate:categories --workspace=backend",
    "retry:refunds": "npm run retry:refunds --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3"
  }
}
