{
  "name": "tienda-ropa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && npm run dev",
    "build": "tsc -b && vite build && cd backend && npm run build",
    "start": "cd backend && NODE_ENV=production node dist/index.js",
    "lint": "eslint .",
    "test": "tsx --test src/utils/shippingAddress.test.ts src/utils/stockAdjustments.test.ts && cd backend && npm test",
    "preview": "vite preview",
    "seed:admin": "cd backend && npm run seed:admin",
    "seed:products": "cd backend && npm run seed:products",
    "migrate:categories": "cd backend && npm run migrate:categories",
    "retry:refunds": "cd backend && npm run retry:refunds"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^10.0.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "firebase": "^12.14.0",
    "html2pdf.js": "^0.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
