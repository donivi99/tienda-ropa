# Backend
PORT=3000
# CORS: orígenes permitidos en backend/src/index.ts (local + Vercel)
# CORS_ORIGIN ya no se usa; editar el array en index.ts si cambia el dominio de producción

# Firebase Admin SDK (Firebase Console → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREEMPLAZA_CON_LA_CLAVE_DEL_JSON\n-----END PRIVATE KEY-----\n"

# Admin seed script (npm run seed:admin)
ADMIN_SEED_EMAIL=admin@tiendaropa.com
ADMIN_SEED_PASSWORD=pon_una_contraseña_segura
ADMIN_SEED_NAME=Administrador

# Stripe (modo test — Desarrolladores → Claves de API)
# Clave secreta estándar (sk_test_). No usar la clave restringida (rk_test_).
STRIPE_SECRET_KEY=sk_test_...

# Secreto de webhook (whsec_). Opcional en local; ver backend/README.md#secreto-de-webhook-whsec
# STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Sandbox — developer.paypal.com → Apps & Credentials)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# ID del webhook registrado en PayPal (obligatorio en producción)
# PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
