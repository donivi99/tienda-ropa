# Backend
PORT=3000
CORS_ORIGIN=http://localhost:3001

# Firebase Admin SDK (Firebase Console → Service Accounts → Generate new private key)
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREEMPLAZA_CON_LA_CLAVE_DEL_JSON\n-----END PRIVATE KEY-----\n"

# Admin seed script (npm run seed:admin)
ADMIN_SEED_EMAIL=admin@tiendaropa.com
ADMIN_SEED_PASSWORD=pon_una_contraseña_segura
ADMIN_SEED_NAME=Administrador

