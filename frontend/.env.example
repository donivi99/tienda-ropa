# Variables de entorno del frontend (VITE_*)
# Copia a frontend/.env o mantén un .env en la raíz del monorepo (Vite usa envDir: '..')
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_API_URL=http://localhost:3000

# Cloudinary (imágenes)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Stripe — Clave publicable (Desarrolladores → Claves de API → Clave publicable)
# No confundir con la clave restringida (rk_test_) ni con el secreto de webhook (whsec_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal — Client ID público (Sandbox o Live). El secreto va solo en backend/.env
# VITE_PAYPAL_CLIENT_ID=

# Tienda (opcional — aparece en recibos PDF)
# VITE_STORE_NAME=TiendaRopa
# VITE_STORE_EMAIL=contacto@ejemplo.com

